{
   "name": "Open Link In Another Window",
   "description": "Open a link in a selected Chrome window from the link context menu or with Shift+click.",
   "version": "2.0",
   "manifest_version": 3,
   "permissions": [
      "contextMenus",
      "tabs"
   ],
   "background": {
      "service_worker": "open-in-window-bg.js"
   },
   "content_scripts": [
      {
         "matches": [
            "<all_urls>"
         ],
         "js": [
            "shift-click-picker.js"
         ],
         "run_at": "document_start"
      }
   ],
   "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   }
}
